# Copy to deploy/.env on the server. chmod 600, owner ubuntu. NEVER commit the
# real file — it holds live secrets. See deploy/README.md for the full runbook.

# ---------------------------------------------------------------------------
# Image (used by docker-compose.yml `app`/`worker`/`migrate` services)
# ---------------------------------------------------------------------------
# Set by CI on deploy (ghcr.io/bookeat1/backend). For a manual first bring-up
# on a fresh box, leave IMAGE_TAG=local and run `docker compose build`.
IMAGE_REPO=ghcr.io/bookeat1/backend
IMAGE_TAG=local
# Written automatically by deploy/scripts/remote-deploy.sh after a successful
# deploy (the tag that was CURRENT right before this one). Used by
# deploy/scripts/rollback.sh for the one-line manual rollback. Leave blank on
# first bring-up — there is nothing to roll back to yet.
PREVIOUS_IMAGE_TAG=

# ---------------------------------------------------------------------------
# Reverse proxy (Caddyfile)
# ---------------------------------------------------------------------------
# http://:80 = plain HTTP on the bare IP (current state, DNS not delegated).
# Flip to the real hostname once DNS resolves here; Caddy then gets TLS
# automatically. See deploy/README.md "DNS cutover" section.
#   prod: SITE_ADDRESS=backend.book-eat.com
#   test: SITE_ADDRESS=test.backend.book-eat.com
SITE_ADDRESS=http://:80

# ---------------------------------------------------------------------------
# Application (internal/bootstrap/config.go)
# ---------------------------------------------------------------------------
APP_NAME=backend-core
# development | staging | production — production also disables /docs.
APP_ENV=production
APP_URL=0.0.0.0:8080
APP_LOG_LEVEL=info
# Comma-separated allowed CORS origins. "*" = any origin, no credentials.
APP_CORS_ORIGINS=*
# Comma-separated IPs/CIDRs trusted to set X-Forwarded-For — only Caddy's own
# address on the compose network should be here (gin's ClientIP() otherwise
# falls back to the raw TCP peer, i.e. Caddy's address for every request,
# which is safe but not per-real-client — see AppConfig.TrustedProxies's doc).
# TODO(verify): this compose file defines no custom `networks:` section, so
# the bridge subnet is whatever Docker assigns per project — find Caddy's
# actual address with `docker compose exec app getent hosts caddy` (or
# `docker network inspect` the project's default network) after first
# bring-up and set it here; do not guess a subnet.
APP_TRUSTED_PROXIES=

# Per-client-IP request budgets (middleware.RateLimit) — see
# .env.example (repo root) for the full list of RATE_LIMIT_* variables and
# their defaults; only listing the master switch here since the defaults are
# sane for prod as-is.
RATE_LIMIT_ENABLED=true

# ---------------------------------------------------------------------------
# PostgreSQL — application connection (DB_HOST is set by compose to
# "postgres"; do not override it here).
# ---------------------------------------------------------------------------
DB_PORT=5432
DB_DATABASE=bookeat
DB_USERNAME=bookeat
# Generate: openssl rand -base64 32
DB_PASSWORD=
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# ---------------------------------------------------------------------------
# PostgreSQL — server tuning (docker-compose.yml `postgres` service command).
# Different per host; see deploy/README.md for the numbers used on prod
# (8 vCPU / 15GB RAM) vs test (4 vCPU / 3GB RAM).
# ---------------------------------------------------------------------------
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=8MB
PG_EFFECTIVE_CACHE_SIZE=768MB
PG_MAINTENANCE_WORK_MEM=64MB
PG_MAX_CONNECTIONS=100
PG_MEM_LIMIT=1g
APP_MEM_LIMIT=512m
WORKER_MEM_LIMIT=256m

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# RSA private key, PEM, one line with literal \n (generate:
# `openssl genrsa 2048 | awk '{printf "%s\\n", $0}'`). NEVER a shared/dev key
# in a real environment.
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KID=bookeat-prod-2026-07
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_OTP_TTL=5m
AUTH_OTP_RATE_PER_MIN=1
AUTH_OTP_RATE_PER_HOUR=5
# Must be false outside development — echoes the OTP code in the API response.
AUTH_OTP_DEV_EXPOSE=false

# ---------------------------------------------------------------------------
# Booking policy (global defaults, per-venue overridable — see config.go)
# ---------------------------------------------------------------------------
BOOKING_DEFAULT_DURATION_MINUTES=90
BOOKING_DEFAULT_BUFFER_MINUTES=0
BOOKING_DEFAULT_LEAD_MINUTES=60
BOOKING_DEFAULT_HORIZON_DAYS=60
BOOKING_DEFAULT_CANCEL_DEADLINE_MINUTES=180
BOOKING_DEFAULT_CONFIRM_SLA_MINUTES=120
BOOKING_DEFAULT_MAX_GUESTS=20
BOOKING_DEFAULT_AUTO_CONFIRM=true
BOOKING_TIMEZONE_FALLBACK=Asia/Almaty
BOOKING_RATE_LIMIT=10
BOOKING_RATE_WINDOW=1h
BOOKING_SLOT_STEP_MINUTES=30

# ---------------------------------------------------------------------------
# Background worker (cmd/worker)
# ---------------------------------------------------------------------------
WORKER_TICK_INTERVAL=1m
WORKER_NO_SHOW_GRACE=30m
WORKER_BATCH_SIZE=100

# ---------------------------------------------------------------------------
# Payments — master switch off by default (spec: a deliberate act to enable).
# Acquirer credentials never reach the DB, only env — see
# internal/infrastructure/payment/{freedompay,tiptoppay}/config.go.
# ---------------------------------------------------------------------------
PAYMENTS_ENABLED=false
PAYMENTS_DEFAULT_PROVIDER=freedompay
PAYMENTS_SERVICE_FEE_BPS=350
PAYMENTS_REFUND_ACQUIRING_BPS=100
PAYMENTS_DEPOSIT_DEFAULT_MINOR=0
PAYMENTS_HOLD_TTL=96h
# This deploy's own externally-reachable origin (no trailing slash) — builds
# the FreedomPay webhook CallbackURL server-side. Required for guest checkout
# to work at all once payments go live.
PAYMENTS_PUBLIC_BASE_URL=https://api.bookeat.kz

# FreedomPay (leave blank until payments go live; PAYMENTS_ENABLED=false makes
# these inert)
FREEDOMPAY_API_URL=https://api.freedompay.kz
FREEDOMPAY_MERCHANT_ID=
FREEDOMPAY_SECRET_KEY=
FREEDOMPAY_RESULT_SCRIPT_NAME=freedompay
FREEDOMPAY_TESTING_MODE=false

# TipTopPay (leave blank until payments go live)
TIPTOPPAY_API_URL=https://api.tiptoppay.kz
TIPTOPPAY_PUBLIC_ID=
TIPTOPPAY_API_SECRET=
TIPTOPPAY_TEST_MODE=false

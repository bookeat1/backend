# Copy to .env for local development. .env is git-ignored.
# Real environment variables (shell / Docker / orchestrator) take precedence.

# Application
APP_NAME=backend-core
APP_ENV=development       # development | staging | production
APP_URL=0.0.0.0:8080
APP_LOG_LEVEL=info         # debug | info | warn | error
APP_LOG_FORMAT=json        # json | text — text читаемее при локальной разработке
# Comma-separated allowed CORS origins. "*" allows any origin (no credentials);
# an explicit list echoes matching origins and permits credentials.
APP_CORS_ORIGINS=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=bookeat
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# DB connection pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# Auth
# RSA private key in PEM (generate: openssl genrsa 2048). One line with \n or a
# quoted multiline value. NEVER commit a real key.
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KID=bookeat-dev
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_OTP_TTL=5m
AUTH_OTP_RATE_PER_MIN=1
AUTH_OTP_RATE_PER_HOUR=5
AUTH_OTP_DEV_EXPOSE=false

# Booking policy (global defaults). Any restaurant may override these per venue
# via the NULLABLE restaurants.booking_* / timezone / auto_confirm columns —
# NULL there means "use the value from here".
BOOKING_DEFAULT_DURATION_MINUTES=90
BOOKING_DEFAULT_BUFFER_MINUTES=0
BOOKING_DEFAULT_LEAD_MINUTES=60
BOOKING_DEFAULT_HORIZON_DAYS=60
BOOKING_DEFAULT_CANCEL_DEADLINE_MINUTES=180
BOOKING_DEFAULT_CONFIRM_SLA_MINUTES=120
BOOKING_DEFAULT_MAX_GUESTS=20
BOOKING_DEFAULT_AUTO_CONFIRM=true
# IANA name used when restaurants.timezone is NULL
BOOKING_TIMEZONE_FALLBACK=Asia/Almaty
# Anti-fraud: at most BOOKING_RATE_LIMIT booking attempts per normalized phone
# within BOOKING_RATE_WINDOW (Go duration).
BOOKING_RATE_LIMIT=10
BOOKING_RATE_WINDOW=1h
# Background booking worker (cmd/worker)
# How often the worker wakes up (Go duration).
WORKER_TICK_INTERVAL=1m
# How long after ends_at a booking is left alone before it is closed as
# completed (guest had arrived) or no_show (guest was never marked arrived).
WORKER_NO_SHOW_GRACE=30m
# Bookings claimed per pass (FOR UPDATE SKIP LOCKED batch size).
WORKER_BATCH_SIZE=100

# Granularity of generated bookable start times for venues that publish opening
# hours but no explicit restaurant_time_slots rows.
BOOKING_SLOT_STEP_MINUTES=30
# Payments (global defaults). A restaurant may override most of these per venue
# via the NULLABLE restaurants.payments_enabled / deposit_* /
# preorder_payment_required / service_fee_bps / payment_provider columns — NULL
# there means "use the value from here".
# Master switch: off by default. Turning payments on is a deliberate act.
PAYMENTS_ENABLED=false
# Acquirer used when the venue has no preference or its choice is disabled in
# the payment_providers registry: freedompay | tiptoppay
PAYMENTS_DEFAULT_PROVIDER=freedompay
# BookEat service fee charged to the guest, in basis points (350 = 3.5%).
PAYMENTS_SERVICE_FEE_BPS=350
# Withheld from a refund to cover the cost of moving money back, in basis points
# of the total (100 = 1%). A cost booked to the `acquirer` ledger account, not
# platform revenue.
PAYMENTS_REFUND_ACQUIRING_BPS=100
# Deposit per booking in tiyn (100 = 1 ₸) when the venue requires one but sets
# no amount of its own. 0 = no default deposit.
PAYMENTS_DEPOSIT_DEFAULT_MINOR=0
# Global fallback for restaurants.deposit_required / preorder_payment_required
# when a venue sets neither override column. Without these, a restaurant
# running on the global defaults could never take a payment at all (payments
# review 2026-07-23, item #10) — a venue's own override still wins when set.
PAYMENTS_DEPOSIT_REQUIRED=false
PAYMENTS_PREORDER_PAYMENT_REQUIRED=false
# How long an authorization (hold) is expected to stay valid (Go duration).
# The acquirer has the final say; this drives payments.expires_at.
# FreedomPay auto-clears an uncleared two-stage hold after 5 days, so a longer
# TTL would silently charge the guest instead of expiring. Verify on sandbox.
PAYMENTS_HOLD_TTL=96h
# This backend's own externally-reachable origin (no trailing slash), used
# ONLY to build the acquirer webhook CallbackURL server-side — never taken
# from the client. Required for POST /bookings/{id}/payment to work at all
# (FreedomPay needs somewhere to call back); leave unset in an environment
# with no public URL yet and that route answers 422, not a silent no-op.
PAYMENTS_PUBLIC_BASE_URL=https://api.bookeat.kz

# Background payments reconciliation worker (usecase/payments.Reconciler).
# KNOWN GAP: read here, but not yet started from cmd/worker — that needs a
# real Postgres implementation of the payments repositories, which does not
# exist in this branch yet (only in-memory test fakes do).
# How often the worker wakes up (Go duration).
PAYMENTS_RECONCILE_TICK_INTERVAL=2m
# How long a payment may sit in `capturing`/`voiding`, or a refund in
# `in_flight`/`pending`, before it counts as stuck rather than a normal
# request still in flight.
PAYMENTS_RECONCILE_STUCK_AFTER=10m
# How long a `created`/`authorized` payment with a provider payment id may go
# without a status change before the worker asks the acquirer directly, in
# case its webhook was lost. Deliberately much longer than STUCK_AFTER: an
# authorized hold sitting untouched for hours is completely normal.
PAYMENTS_RECONCILE_LOST_WEBHOOK_AFTER=1h
# Rows claimed per pass, per stage (FOR UPDATE SKIP LOCKED batch size).
PAYMENTS_RECONCILE_BATCH_SIZE=50
# Consecutive unresolved attempts before a row is flagged NeedsManualReview
# and the worker stops calling the acquirer for it — build a Grafana alert on
# the payment.reconcile_manual_review event, not on this number directly.
PAYMENTS_RECONCILE_MAX_ATTEMPTS=5
# Minimum spacing between two acquirer calls this worker makes (avalanche
# guard): a batch of many stuck rows must not become simultaneous requests.
PAYMENTS_RECONCILE_PROVIDER_MIN_GAP=200ms

# Acquirer credentials are NOT listed here on purpose: each adapter reads its
# own keys from env (FREEDOMPAY_*, TIPTOPPAY_*) and they never reach the DB.

# Copy to .env for local development. .env is git-ignored.
# Real environment variables (shell / Docker / orchestrator) take precedence.

# Application
APP_NAME=backend-core
APP_ENV=development       # development | staging | production
APP_URL=0.0.0.0:8080
APP_LOG_LEVEL=info        # debug | info | warn | error
# Comma-separated allowed CORS origins. "*" allows any origin (no credentials);
# an explicit list echoes matching origins and permits credentials.
APP_CORS_ORIGINS=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=bookeat
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable

# DB connection pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=5m

# Auth
# RSA private key in PEM (generate: openssl genrsa 2048). One line with \n or a
# quoted multiline value. NEVER commit a real key.
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KID=bookeat-dev
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h
AUTH_OTP_TTL=5m
AUTH_OTP_RATE_PER_MIN=1
AUTH_OTP_RATE_PER_HOUR=5
AUTH_OTP_DEV_EXPOSE=false

# Booking policy (global defaults). Any restaurant may override these per venue
# via the NULLABLE restaurants.booking_* / timezone / auto_confirm columns —
# NULL there means "use the value from here".
BOOKING_DEFAULT_DURATION_MINUTES=90
BOOKING_DEFAULT_BUFFER_MINUTES=0
BOOKING_DEFAULT_LEAD_MINUTES=60
BOOKING_DEFAULT_HORIZON_DAYS=60
BOOKING_DEFAULT_CANCEL_DEADLINE_MINUTES=180
BOOKING_DEFAULT_CONFIRM_SLA_MINUTES=120
BOOKING_DEFAULT_MAX_GUESTS=20
BOOKING_DEFAULT_AUTO_CONFIRM=true
# IANA name used when restaurants.timezone is NULL
BOOKING_TIMEZONE_FALLBACK=Asia/Almaty
# Anti-fraud: at most BOOKING_RATE_LIMIT booking attempts per normalized phone
# within BOOKING_RATE_WINDOW (Go duration).
BOOKING_RATE_LIMIT=10
BOOKING_RATE_WINDOW=1h
# Background booking worker (cmd/worker)
# How often the worker wakes up (Go duration).
WORKER_TICK_INTERVAL=1m
# How long after ends_at a booking is left alone before it is closed as
# completed (guest had arrived) or no_show (guest was never marked arrived).
WORKER_NO_SHOW_GRACE=30m
# Bookings claimed per pass (FOR UPDATE SKIP LOCKED batch size).
WORKER_BATCH_SIZE=100

# Granularity of generated bookable start times for venues that publish opening
# hours but no explicit restaurant_time_slots rows.
BOOKING_SLOT_STEP_MINUTES=30
